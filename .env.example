# ─── Her Canvas environment variables ───────────────────────────────
# Copy this file to ".env" and fill in real values.
# In production, set these in Netlify: Site settings → Environment variables.
# NOTE: Only VITE_* vars are exposed to the browser. Everything else stays
# server-side inside Netlify Functions, so your secret keys never leak.

# ── Supabase (auth + database + image storage) ──
# Get these from supabase.com → your project → Project Settings → API
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
# Service-role key is SECRET — used only inside functions, never in the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── AI styling brain (pick ONE) ──
# Option A — Groq (FREE, no card). Get a key at console.groq.com → API Keys.
# This is used automatically when set.
GROQ_API_KEY=gsk_...
# Optional model override.
GROQ_MODEL=llama-3.3-70b-versatile

# Option B — Anthropic / Claude (paid, best quality). Used only if no Groq key.
# Get from console.anthropic.com → API Keys
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# ── Photo sources for mood boards (both have free tiers) ──
# pexels.com/api  &  unsplash.com/developers
PEXELS_API_KEY=your-pexels-key
UNSPLASH_ACCESS_KEY=your-unsplash-access-key
